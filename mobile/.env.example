# BRIDGE Worklog — environment variables.
# Copy to ".env" and fill in when each integration is ready. ALL are optional:
# with none set, the app runs fully on local storage with mock AI and no ads.

# --- EAS / build (app.config.ts) ---
# From `eas init` / your Expo account. Needed only to build with EAS.
EAS_PROJECT_ID=
EAS_OWNER=

# --- AdMob (production builds only) ---
# Native app ids (added to the build via the config plugin). Requires
# `npx expo install react-native-google-mobile-ads` before a production build.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=
# Banner unit ids read at runtime (EXPO_PUBLIC_* are inlined into the JS bundle).
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=

# --- RevenueCat (in-app purchase: "remove ads") ---
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=

# --- Supabase (cloud sync; optional, app is local-first) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Managed AI backend (real generation + translation) ---
# If you deploy the Supabase Edge Function `ai`, the client derives the URL from
# SUPABASE_URL automatically — leave this blank. Set it only to host elsewhere.
EXPO_PUBLIC_AI_BACKEND_URL=
# Shared secret sent as x-app-token; must equal the server's APP_SHARED_SECRET.
# Deters direct abuse of the (no-JWT) function. Leave blank to disable the check.
EXPO_PUBLIC_APP_TOKEN=
# The actual AI key is a SERVER secret, never in the app bundle. Use a PAID-tier
# key — the free tier may use your data to improve Google's products. For Supabase:
#   supabase functions deploy ai --no-verify-jwt
#   supabase secrets set GEMINI_API_KEY=xxxx
#   supabase secrets set APP_SHARED_SECRET=xxxx   # match EXPO_PUBLIC_APP_TOKEN
#   (optional) GEMINI_MODEL_LITE / GEMINI_MODEL_FLASH / GEMINI_MODEL_PRO
